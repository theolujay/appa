# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env
.envrc

# Editor/IDE
.idea/
.vscode/

# Vagrant VM data and logs
deploy/ansible/dev/.vagrant/
deploy/ansible/dev/*.log

# Ansible fact cache artifacts (created by Vagrant's provisioner)
default:
{cache_update_time:*

# Auto-generated by ansible-galaxy install — regenerates on every install
**/.galaxy_install_info

# Upstream CI/lint config from Galaxy roles (not user-authored)
**/.travis.yml
# **/.yamllint

# Ansible virtual environment
deploy/ansible/.venv/

# Ansible runtime cache (collections, modules, roles downloaded at runtime)
deploy/ansible/.ansible/

# External Galaxy roles — managed by requirements.yml
deploy/ansible/roles/geerlingguy.docker/

# Build artifact from go:generate (embed copy of deploy/ansible/)
internal/cli/ansible/_embed/

# Molecule auto-generated role symlinks (created by molecule prerun or manually)
deploy/ansible/roles/*/molecule/*/roles/
deploy/ansible/playbooks/*/molecule/*/roles/

# Local TODO tracking — not part of the project
TODO.md
