# ── Database ──────────────────────────────────────────
APPA_DB_DSN='postgres://appa:pa55word@db:5444/appa?sslmode=disable'
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_MAX_IDLE_TIME=15m

POSTGRES_DB=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres

# ── Environment ───────────────────────────────────────
ENV=development
PORT=8080
PRODUCTION_HOST_IP=

# ── Rate Limiter ──────────────────────────────────────
LIMITER_RPS=2
LIMITER_BURST=4
LIMITER_ENABLED=true

# ── SMTP ──────────────────────────────────────────────
# Use https://mailtrap.io for development, or any SMTP provider.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER="Appa <no-reply@appa.theolujay.dev>"

# ── CORS ──────────────────────────────────────────────
CORS_TRUSTED_ORIGINS="https://appa.theolujay.dev http://localhost:5173 http://localhost http://127.0.0.1"
