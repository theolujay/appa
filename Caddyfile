{
    admin 0.0.0.0:2019
    auto_https off
}

:80 {
    log {
        output stdout
    }

    @dashboard host localhost 127.0.0.1

    handle @dashboard {
        # API Proxy
        handle /deployments* {
            reverse_proxy {$API_URL:api:8080} {
                header_up Host {host}
                header_up X-Real-IP {remote_host}
            }
        }

        # Frontend Proxy (Vite)
        handle {
            reverse_proxy {$UI_URL:ui:5173} {
                header_up Host {host}
            }
        }
    }

    # Fallback for other hosts
    handle {
        header Content-Type text/plain
        respond "Appa Ingress: No route configured for {host}" 404
    }
}
